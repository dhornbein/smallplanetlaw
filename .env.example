# Mailchimp Configuration
# Get your API key from: https://admin.mailchimp.com/account/api/
MAILCHIMP_API_KEY=

# Server prefix is the part after the dash in your API key (e.g., if your key ends in "-us19", use "us19")
MAILCHIMP_SERVER_PREFIX=

# Get your List ID from: Audience > Settings > Audience name and defaults
MAILCHIMP_LIST_ID=

# Get your User ID from your Mailchimp account URL or archive URLs
MAILCHIMP_USER_ID=
